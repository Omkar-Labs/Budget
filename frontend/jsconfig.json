{
    "compilerOptions":{
        "target":"ES6",
        "module":"esnext",
        "resolveJsonModule": true,
        "moduleResolution": "node", 
        "esModuleInterop": true, 
        "baseUrl":".",
        "paths":{
            "@/*":["./src/*"]
        },
        "checkJs":true,
        "jsx":"react-jsx",
        "lib":["dom","dom.iterable","esnext"],
    },
    "exclude":["node_modules","dist"]
}